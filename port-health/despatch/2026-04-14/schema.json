{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Port Health Despatch",
  "description": "Schema for the Despatch signal.",
  "type": "object",
  "required": ["originRecordID", "originSystemCode", "payload"],
  "properties": {
    "originRecordID": {
      "type": "string",
      "description": "The human-readable reference for provenance (e.g., TRIP-4455)."
    },
    "originSystemCode": {
      "type": "string",
      "description": "The originating system code (e.g., TWIN, DESTIN8)."
    },
    "category": {
      "type": "array",
      "description": "Metadata tags for searching and filtering.",
      "items": { "type": "string" },
      "examples": [["despatch", "test"]]
    },
    "payload": {
      "title": "Despatch Payload",
      "type": "object",
      "required": [
        "plannedDepartureTime",
        "portOfExit",
        "portOfExitCode",
        "portOfEntry",
        "portOfEntryCode"
      ],
      "properties": {
        "plannedDepartureTime": { "type": "string", "format": "date-time" },
        "actualDepartureTime": { "type": "string", "format": "date-time" },
        "portOfExit": { "type": "string" },
        "portOfExitCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$" },
        "portOfEntry": { "type": "string" },
        "portOfEntryCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$" },
        "destinationPlant": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
