{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Port Health Master Schema",
  "description": "Unified schema for Pre-notification and Despatch signals with Port/LOCODE.",
  "type": "object",
  "required": ["sourceRef", "systemCode", "payload"],
  "properties": {
    "sourceRef": {
      "type": "string",
      "description": "The human-readable reference for provenance (e.g., PRE123456)."
    },
    "systemCode": {
      "type": "string",
      "description": "The originating system code (e.g., TWIN, DESTIN8)."
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "The system-generated UUID. Required in Despatch to link to the original Pre-notification."
    },
    "category": {
      "type": "array",
      "description": "Metadata tags for searching and filtering.",
      "items": { "type": "string" },
      "examples": [["pre-notification", "test"]]
    },
    "payload": {
      "oneOf": [
        {
          "title": "Pre-notification",
          "type": "object",
          "required": [
            "cnCodes",
            "commodityDescription",
            "countryOfOrigin",
            "importerEORI",
            "location",
            "mode",
            "portOfExit",
            "portOfEntry",
            "transportMeans"
          ],
          "properties": {
            "chedNumbers": { "type": "array", "items": { "type": "string" } },
            "cnCodes": { "type": "array", "items": { "type": "string" } },
            "commodityDescription": { "type": "string" },
            "countryOfOrigin": { "type": "string", "minLength": 2, "maxLength": 2 },
            "exporterEORI": { "type": "string" },
            "importerEORI": { "type": "string" },
            "location": { "type": "string" },
            "mode": { "type": "string" },
            "portOfExit": { "type": "string", "description": "Name of departure port." },
            "portOfExitCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$", "description": "Optional UN/LOCODE for departure." },
            "portOfEntry": { "type": "string", "description": "Name of arrival port." },
            "portOfEntryCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$", "description": "Optional UN/LOCODE for arrival." },
            "transportMeans": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["transportMovementType", "identifier"],
                "properties": {
                  "transportMovementType": { "type": "string" },
                  "identifier": { "type": "string" },
                  "affixedSeal": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "sealNumbers": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        {
          "title": "Despatch",
          "type": "object",
          "required": [
            "plannedDepartureTime",
            "portOfExit",
            "portOfEntry"
          ],
          "properties": {
            "destinationPlant": { "type": "string" },
            "plannedDepartureTime": { "type": "string", "format": "date-time" },
            "actualDepartureTime": { "type": "string", "format": "date-time" },
            "portOfExit": { "type": "string" },
            "portOfExitCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$" },
            "portOfEntry": { "type": "string" },
            "portOfEntryCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
