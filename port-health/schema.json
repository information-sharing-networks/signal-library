{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "sourceRef",
    "systemCode",
    "payload"
  ],
  "properties": {
    "sourceRef": {
      "type": "string",
      "description": "The unique reference or job number from the originating system for traceability."
    },
    "systemCode": {
      "type": "string",
      "description": "Code identifying the source system (e.g., TWIN, DESTIN8,)."
    },
    "payload": {
      "oneOf": [
        {
          "title": "Pre-notification payload",
          "type": "object",
          "required": [
            "cnCodes",
            "commodityDescription",
            "countryOfOrigin",
            "exporterEORI",
            "importerEORI",
            "location",
            "mode"
          ],
          "properties": {
            "chedNumbers": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "cnCodes": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "commodityDescription": { "type": "string" },
            "countryOfOrigin": { "type": "string" },
            "exporterEORI": { "type": "string" },
            "importerEORI": { "type": "string" },
            "location": { "type": "string" },
            "mode": { "type": "string" },
            "transportMeans": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["transportMovementType", "identifier"],
                "properties": {
                  "transportMovementType": { "type": "string" },
                  "identifier": { "type": "string", "description": "Container or trailer number" },
                  "affixedSeal": { "type": "string", "description": "ID of the specific seal on this unit" }
                },
                "additionalProperties": false
              },
              "minItems": 1
            },
            "sealNumbers": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          },
          "additionalProperties": false
        },
        {
          "title": "Despatch payload",
          "type": "object",
          "required": [
            "plannedDepartureTime",
            "portOfExit",
            "portOfEntry"
          ],
          "properties": {
            "destinationPlant": { "type": "string" },
            "plannedDepartureTime": { "type": "string", "format": "date-time" },
            "actualDepartureTime": { "type": "string", "format": "date-time" },
            "portOfExit": { "type": "string" },
            "portOfEntry": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
