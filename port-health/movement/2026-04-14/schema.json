{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Port Health Movement Notification",
  "description": "Schema for the Movement Notification signal.",
  "type": "object",
  "required": ["originRecordID", "originSystemCode", "payload"],
  "properties": {
    "originRecordID": {
      "type": "string",
      "description": "The human-readable reference for provenance (e.g., PRE123456)."
    },
    "originSystemCode": {
      "type": "string",
      "description": "The originating system code (e.g., TWIN, DESTIN8)."
    },
    "category": {
      "type": "array",
      "description": "Metadata tags for searching and filtering.",
      "items": { "type": "string" },
      "examples": [["Movement Notification", "test"]]
    },
    "payload": {
      "title": "Movement Notification Payload",
      "type": "object",
      "required": [
        "cnCodes",
        "commodityDescription",
        "countryOfOrigin",
        "importerEORI",
        "location",
        "mode",
        "portOfExit",
        "portOfExitCode",
        "portOfEntry",
        "portOfEntryCode",
        "transportMeans"
      ],
      "properties": {
        "chedNumbers": { "type": "array", "items": { "type": "string" } },
        "cnCodes": { "type": "array", "items": { "type": "string" } },
        "commodityDescription": { "type": "string" },
        "countryOfOrigin": { "type": "string", "minLength": 2, "maxLength": 2 },
        "exporterEORI": { "type": "string" },
        "importerEORI": { "type": "string" },
        "location": { "type": "string" },
        "mode": { "type": "string" },
        "portOfExit": { "type": "string", "description": "Name of departure port." },
        "portOfExitCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$", "description": "UN/LOCODE for departure." },
        "portOfEntry": { "type": "string", "description": "Name of arrival port." },
        "portOfEntryCode": { "type": "string", "pattern": "^[A-Z]{2}[A-Z2-9]{3}$", "description": "UN/LOCODE for arrival." },
        "transportMeans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["transportMovementType", "identifier"],
            "properties": {
              "transportMovementType": { "type": "string" },
              "identifier": { "type": "string" },
              "affixedSeal": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "sealNumbers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
